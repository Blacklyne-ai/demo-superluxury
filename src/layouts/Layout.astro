---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site, contact } from '../data/site';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  navVariant?: 'transparent' | 'solid';
  wide?: boolean;
}

const {
  title = 'Super Luxury Car Rental Dubai - Exotic & Supercar Hire',
  description = 'Handpicked luxury, sports & SUV rentals in Dubai - Rolls-Royce, Ferrari, Lamborghini, Range Rover and more. Free delivery anywhere in Dubai. 24/7 support. From AED 1,000/day.',
  image = '/og.jpg',
  navVariant = 'transparent',
} = Astro.props;

const canonical = new URL(Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '/') || '/', Astro.site).href;
const ldJson = {
  '@context': 'https://schema.org',
  '@type': 'AutoRental',
  name: site.name,
  legalName: site.legalName,
  url: Astro.site?.href,
  image: new URL(image, Astro.site).href,
  telephone: contact.phonePrimary,
  email: contact.email,
  priceRange: 'AED 1,000+',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Office F4 - 53, Al Khaimah 2 Building',
    addressLocality: 'Al Barsha, Dubai',
    addressCountry: 'AE',
  },
  areaServed: 'Dubai, United Arab Emirates',
  sameAs: [contact.instagram, contact.facebook],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#FAF8F3" />

    <!-- Self-hosted fonts (font-display:optional in global.css → CLS≈0) -->
    <link rel="preload" href="/fonts/inter.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/cormorant-500.woff2" as="font" type="font/woff2" crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />

    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(ldJson)} is:inline />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-pill focus:bg-gold focus:px-5 focus:py-3 focus:text-ivory">Skip to content</a>

    <Nav variant={navVariant} />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <!-- Persistent WhatsApp button -->
    <a href={contact.whatsapp} target="_blank" rel="noopener" aria-label="Chat on WhatsApp"
      class="group fixed bottom-5 right-5 z-[95] inline-flex items-center gap-2.5 rounded-full bg-[#25D366] py-3 pl-3.5 pr-3.5 text-white shadow-[0_10px_30px_-6px_rgba(37,211,102,0.55)] transition-all duration-300 hover:pr-5 sm:bottom-6 sm:right-6">
      <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor" aria-hidden="true"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21 5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm0 18.15c-1.52 0-3.01-.41-4.31-1.18l-.31-.18-3.2.84.85-3.12-.2-.32a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.24 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.17.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.24-1.48-1.38-1.73-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.12-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/></svg>
      <span class="hidden max-w-0 overflow-hidden whitespace-nowrap text-[0.82rem] font-semibold opacity-0 transition-all duration-300 group-hover:max-w-[120px] group-hover:opacity-100 sm:inline">WhatsApp</span>
    </a>

    <!-- Cookie / privacy note (only first-party storage = wishlist). Hidden inside iframe embeds. -->
    <div data-consent class="fixed inset-x-3 bottom-3 z-[90] hidden sm:inset-x-auto sm:bottom-6 sm:left-6 sm:max-w-sm">
      <div class="card shadow-lift p-5">
        <p class="text-sm leading-relaxed text-mist">
          We use essential first-party storage only (your saved cars). No tracking cookies. See our
          <a href="/privacy" class="text-ivory underline decoration-gold/50 underline-offset-2 hover:decoration-gold">privacy note</a>.
        </p>
        <button data-consent-ok class="btn-gold mt-4 w-full text-sm">Got it</button>
      </div>
    </div>

    <script>
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ── Lenis smooth scroll + parallax (skipped for reduced-motion) ──
      const parallaxEls = Array.from(document.querySelectorAll('[data-parallax]')) as HTMLElement[];
      function updateParallax() {
        const vh = window.innerHeight;
        for (const el of parallaxEls) {
          const r = el.getBoundingClientRect();
          if (r.bottom < -300 || r.top > vh + 300) continue;
          const speed = parseFloat(el.dataset.parallax || '0.15');
          const offset = ((r.top + r.height / 2) - vh / 2) * speed * -1;
          el.style.transform = `translate3d(0, ${offset.toFixed(1)}px, 0)`;
        }
      }
      if (!reduce) {
        import('lenis').then(({ default: Lenis }) => {
          const lenis = new Lenis({ duration: 1.1, smoothWheel: true });
          function raf(t: number) { lenis.raf(t); updateParallax(); requestAnimationFrame(raf); }
          requestAnimationFrame(raf);
        }).catch(() => { window.addEventListener('scroll', updateParallax, { passive: true }); updateParallax(); });
      }

      // ── Scroll reveal (gentle, once). Safe default: visible if JS/observer absent. ──
      const reveals = Array.from(document.querySelectorAll('[data-reveal]')) as HTMLElement[];
      if (reduce || !('IntersectionObserver' in window)) {
        reveals.forEach((el) => { el.style.opacity = '1'; el.style.transform = 'none'; });
      } else {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (!e.isIntersecting) return;
            const el = e.target as HTMLElement;
            const d = Number(el.dataset.delay || 0);
            el.style.transition = `opacity 1.2s cubic-bezier(.22,1,.36,1) ${d}ms, transform 1.2s cubic-bezier(.22,1,.36,1) ${d}ms`;
            el.style.opacity = '1';
            el.style.transform = 'none';
            io.unobserve(el);
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 });
        reveals.forEach((el) => io.observe(el));
      }

      // ── Wishlist (localStorage, global) ──
      const WK = 'slcr-wishlist';
      const read = (): string[] => { try { return JSON.parse(localStorage.getItem(WK) || '[]'); } catch { return []; } };
      const write = (a: string[]) => { try { localStorage.setItem(WK, JSON.stringify(a)); } catch {} };
      const sync = () => {
        const ids = read();
        document.querySelectorAll('[data-wish]').forEach((b) => {
          const el = b as HTMLElement;
          el.setAttribute('aria-pressed', String(ids.includes(el.dataset.id || '')));
          el.classList.toggle('is-saved', ids.includes(el.dataset.id || ''));
        });
        document.querySelectorAll('[data-wish-count]').forEach((c) => {
          const el = c as HTMLElement;
          el.textContent = String(ids.length);
          el.classList.toggle('hidden', ids.length === 0);
        });
        document.dispatchEvent(new CustomEvent('wishlist:change', { detail: ids }));
      };
      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('[data-wish]') as HTMLElement | null;
        if (!btn) return;
        e.preventDefault();
        const id = btn.dataset.id || '';
        const ids = read();
        const i = ids.indexOf(id);
        if (i >= 0) ids.splice(i, 1); else ids.push(id);
        write(ids);
        sync();
      });
      sync();

      // ── Consent note (once). Not shown inside iframe embeds. ──
      let embedded = false;
      try { embedded = window.self !== window.top; } catch { embedded = true; }
      try {
        const bar = document.querySelector('[data-consent]') as HTMLElement | null;
        if (bar && !embedded && !localStorage.getItem('slcr-consent')) {
          bar.classList.remove('hidden');
          bar.querySelector('[data-consent-ok]')?.addEventListener('click', () => {
            localStorage.setItem('slcr-consent', '1');
            bar.classList.add('hidden');
          });
        }
      } catch {}
    </script>
  </body>
</html>
