---
import { Phone, Mail, MapPin, MessageCircle } from '@lucide/astro';
import { site, contact, categories, nav } from '../data/site';
const year = 2026;
---

<footer class="relative border-t border-ivory/10 bg-coal">
  <div class="hr-gold"></div>
  <div class="lux-container py-16 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr_1fr_1.2fr]">
      <!-- Brand -->
      <div>
        <img src="/logo-mark-ink.png" alt={site.name} width="180" height="113" class="h-14 w-auto" />
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-mist">{site.tagline}</p>
        <div class="mt-6 flex items-center gap-3">
          <a href={contact.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="grid h-10 w-10 place-items-center rounded-full border border-ivory/12 text-ivory/70 transition-colors hover:border-gold/60 hover:text-gold">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s0 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.2 15.58 2.2 15.2 2.2 12s0-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.2 8.8 2.2 12 2.2Zm0 1.95c-3.15 0-3.5 0-4.74.07-1.14.05-1.76.24-2.17.4-.55.22-.94.47-1.35.88-.41.41-.66.8-.88 1.35-.16.41-.35 1.03-.4 2.17-.06 1.24-.07 1.59-.07 4.74s0 3.5.07 4.74c.05 1.14.24 1.76.4 2.17.22.55.47.94.88 1.35.41.41.8.66 1.35.88.41.16 1.03.35 2.17.4 1.24.06 1.59.07 4.74.07s3.5 0 4.74-.07c1.14-.05 1.76-.24 2.17-.4.55-.22.94-.47 1.35-.88.41-.41.66-.8.88-1.35.16-.41.35-1.03.4-2.17.06-1.24.07-1.59.07-4.74s0-3.5-.07-4.74c-.05-1.14-.24-1.76-.4-2.17a3.6 3.6 0 0 0-.88-1.35 3.6 3.6 0 0 0-1.35-.88c-.41-.16-1.03-.35-2.17-.4-1.24-.06-1.59-.07-4.74-.07Zm0 3.32a5.03 5.03 0 1 1 0 10.06 5.03 5.03 0 0 1 0-10.06Zm0 8.3a3.27 3.27 0 1 0 0-6.54 3.27 3.27 0 0 0 0 6.54Zm6.4-8.52a1.18 1.18 0 1 1-2.35 0 1.18 1.18 0 0 1 2.35 0Z"/></svg>
          </a>
          <a href={contact.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="grid h-10 w-10 place-items-center rounded-full border border-ivory/12 text-ivory/70 transition-colors hover:border-gold/60 hover:text-gold">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.44 2.9h-2.34V22c4.78-.79 8.43-4.94 8.43-9.94Z"/></svg>
          </a>
          <a href={contact.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp" class="grid h-10 w-10 place-items-center rounded-full border border-ivory/12 text-ivory/70 transition-colors hover:border-gold/60 hover:text-gold">
            <MessageCircle class="h-[18px] w-[18px]" />
          </a>
        </div>
      </div>

      <!-- Fleet -->
      <nav aria-label="Fleet" class="text-sm">
        <p class="eyebrow mb-5">Fleet</p>
        <ul class="space-y-2.5">
          {categories.map((c) => (
            <li><a href={`/fleet?category=${c.slug}`} class="text-ivory/70 transition-colors hover:text-gold">{c.label} cars</a></li>
          ))}
          <li><a href="/fleet" class="font-medium text-gold hover:text-gold-lite">All vehicles</a></li>
        </ul>
      </nav>

      <!-- Company -->
      <nav aria-label="Company" class="text-sm">
        <p class="eyebrow mb-5">Company</p>
        <ul class="space-y-2.5">
          <li><a href="/about" class="text-ivory/70 transition-colors hover:text-gold">About us</a></li>
          <li><a href="/services" class="text-ivory/70 transition-colors hover:text-gold">Services</a></li>
          <li><a href="/book" class="text-ivory/70 transition-colors hover:text-gold">Book now</a></li>
          <li><a href="/contact" class="text-ivory/70 transition-colors hover:text-gold">Contact</a></li>
          <li><a href="/terms" class="text-ivory/70 transition-colors hover:text-gold">Terms &amp; conditions</a></li>
          <li><a href="/privacy" class="text-ivory/70 transition-colors hover:text-gold">Privacy</a></li>
          <li><a href="/legal" class="text-ivory/70 transition-colors hover:text-gold">Legal notice</a></li>
        </ul>
      </nav>

      <!-- Contact -->
      <div class="text-sm">
        <p class="eyebrow mb-5">Visit / call</p>
        <ul class="space-y-3.5 text-ivory/75">
          <li class="flex gap-3"><MapPin class="mt-0.5 h-4 w-4 shrink-0 text-gold" /><span>{contact.address}</span></li>
          <li class="flex gap-3"><Phone class="mt-0.5 h-4 w-4 shrink-0 text-gold" /><span><a href={contact.phonePrimaryHref} class="hover:text-gold">{contact.phonePrimary}</a><br /><a href={contact.phoneSecondaryHref} class="hover:text-gold">{contact.phoneSecondary}</a></span></li>
          <li class="flex gap-3"><Mail class="mt-0.5 h-4 w-4 shrink-0 text-gold" /><a href={contact.emailHref} class="break-all hover:text-gold">{contact.email}</a></li>
        </ul>
        <p class="mt-5 chip-gold">24/7 · Free delivery in Dubai</p>
      </div>
    </div>

    <!-- bottom bar -->
    <div class="mt-14 flex flex-col gap-4 border-t border-ivory/10 pt-7 text-xs text-faint sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {site.legalName} · by {site.operator}. All rights reserved.</p>
      <p class="flex items-center gap-4">
        <span>Cards accepted · Visa · Mastercard</span>
      </p>
    </div>
  </div>
</footer>
