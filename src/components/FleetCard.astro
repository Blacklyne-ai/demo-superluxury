---
import { Heart, ChevronLeft, ChevronRight } from '@lucide/astro';
import { fmtAED, shortName } from '../lib/fleet';
import { categoryMap } from '../data/site';
import type { Car } from '../lib/fleet';

interface Props { car: Car; eager?: boolean }
const { car, eager = false } = Astro.props;
const href = `/fleet/${car.sourceSlug}-${car.id}`;
const imgs = car.images.slice(0, 8);
const cover = imgs[0];
const cat = categoryMap[car.category];
const specLine = [car.specs.seats && `${car.specs.seats} seats`, car.specs.transmission].filter(Boolean).join('  ·  ');
---
<article
  class="group relative"
  data-card
  data-id={`${car.sourceSlug}-${car.id}`}
  data-name={car.name.toLowerCase()}
  data-brand={car.brand}
  data-cats={car.categories.join(',')}
  data-price={car.priceDaily}
  data-seats={car.specs.seats ?? ''}
>
  <div class="group/img relative aspect-[4/3] overflow-hidden rounded-lg bg-coal" data-gallery data-idx="0" data-images={JSON.stringify(imgs)}>
    <a href={href} class="block h-full w-full">
      {cover ? (
        <img data-cardimg src={cover} alt={car.name} width="640" height="480"
          loading={eager ? 'eager' : 'lazy'} decoding="async"
          class="h-full w-full object-cover transition-transform duration-700 ease-luxe group-hover:scale-[1.04]" />
      ) : (
        <div class="grid h-full w-full place-items-center text-faint">No image</div>
      )}
    </a>

    {imgs.length > 1 && (
      <>
        <button data-img-prev aria-label="Previous photo"
          class="absolute left-2.5 top-1/2 grid h-10 w-10 -translate-y-1/2 place-items-center text-white opacity-0 transition-all duration-300 hover:text-gold-lite group-hover/img:opacity-100 max-md:opacity-95"
          style="filter:drop-shadow(0 1px 4px rgb(0 0 0 / 0.7))"><ChevronLeft class="h-6 w-6" stroke-width={2.4} /></button>
        <button data-img-next aria-label="Next photo"
          class="absolute right-2.5 top-1/2 grid h-10 w-10 -translate-y-1/2 place-items-center text-white opacity-0 transition-all duration-300 hover:text-gold-lite group-hover/img:opacity-100 max-md:opacity-95"
          style="filter:drop-shadow(0 1px 4px rgb(0 0 0 / 0.7))"><ChevronRight class="h-6 w-6" stroke-width={2.4} /></button>
        <div data-img-dots class="pointer-events-none absolute bottom-2.5 left-1/2 flex -translate-x-1/2 gap-1.5">
          {imgs.map((_, i) => (
            <span class:list={['h-1.5 w-1.5 rounded-full transition-colors', i === 0 ? 'bg-white' : 'bg-white/45']}></span>
          ))}
        </div>
      </>
    )}

    <button data-wish data-id={`${car.sourceSlug}-${car.id}`} aria-label={`Save ${car.name}`} aria-pressed="false"
      class="absolute right-3 top-3 grid h-9 w-9 place-items-center rounded-full text-white/85 backdrop-blur-sm transition-colors hover:text-gold-lite"
      style="background:rgb(0 0 0 / 0.32)">
      <Heart class="h-[17px] w-[17px]" />
    </button>
  </div>

  <div class="pt-4">
    <!-- mobile: only the model, one line (uniform card heights). desktop: brand · category above. -->
    <p class="hidden truncate text-[0.66rem] uppercase tracking-[0.2em] text-faint sm:block">{car.brand} · {cat?.label ?? car.category}</p>
    <a href={href}><h3 class="truncate font-display text-[1.25rem] leading-tight text-ivory transition-colors group-hover:text-gold sm:mt-1.5 sm:text-[1.45rem]">{shortName(car.id, car.name)}</h3></a>
    <div class="mt-2.5 flex items-end justify-between border-t border-ivory/8 pt-2.5 sm:mt-3 sm:pt-3">
      <p class="price-aed text-[0.9rem] text-gold sm:text-[0.95rem]">{fmtAED(car.priceDaily)} <span class="text-faint">/ day</span></p>
      {specLine && <p class="hidden text-[0.72rem] text-mist sm:block">{specLine}</p>}
    </div>
  </div>
</article>

<script>
  // Inline image carousel for fleet cards (delegated, runs once globally)
  if (!(window as any).__cardGallery) {
    (window as any).__cardGallery = true;
    const step = (btn: HTMLElement, dir: number) => {
      const g = btn.closest('[data-gallery]') as HTMLElement | null;
      if (!g) return;
      let imgs: string[] = [];
      try { imgs = JSON.parse(g.dataset.images || '[]'); } catch {}
      if (imgs.length < 2) return;
      let idx = (Number(g.dataset.idx || 0) + dir + imgs.length) % imgs.length;
      g.dataset.idx = String(idx);
      const img = g.querySelector('[data-cardimg]') as HTMLImageElement | null;
      if (img) img.src = imgs[idx];
      const dots = g.querySelectorAll('[data-img-dots] span');
      dots.forEach((d, i) => { (d as HTMLElement).className = `h-1.5 w-1.5 rounded-full transition-colors ${i === idx ? 'bg-white' : 'bg-white/45'}`; });
    };
    document.addEventListener('click', (e) => {
      const prev = (e.target as HTMLElement).closest('[data-img-prev]') as HTMLElement | null;
      const next = (e.target as HTMLElement).closest('[data-img-next]') as HTMLElement | null;
      if (!prev && !next) return;
      e.preventDefault(); e.stopPropagation();
      step((prev || next)!, prev ? -1 : 1);
    });
  }
</script>
