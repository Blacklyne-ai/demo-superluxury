---
import { Heart } from '@lucide/astro';
import { fmtAED } from '../lib/fleet';
import { categoryMap } from '../data/site';
import type { Car } from '../lib/fleet';

interface Props { car: Car; eager?: boolean }
const { car, eager = false } = Astro.props;
const href = `/fleet/${car.sourceSlug}-${car.id}`;
const cover = car.images[0];
const cat = categoryMap[car.category];
const specLine = [car.specs.seats && `${car.specs.seats} seats`, car.specs.transmission].filter(Boolean).join('  ·  ');
---
<article
  class="group relative"
  data-card
  data-id={`${car.sourceSlug}-${car.id}`}
  data-name={car.name.toLowerCase()}
  data-brand={car.brand}
  data-cats={car.categories.join(',')}
  data-price={car.priceDaily}
  data-seats={car.specs.seats ?? ''}
>
  <a href={href} class="block">
    <div class="relative aspect-[4/3] overflow-hidden bg-coal">
      {cover ? (
        <img src={cover} alt={car.name} width="640" height="480"
          loading={eager ? 'eager' : 'lazy'} decoding="async"
          class="h-full w-full object-cover transition-transform duration-[1.4s] ease-luxe group-hover:scale-[1.05]" />
      ) : (
        <div class="grid h-full w-full place-items-center text-faint">No image</div>
      )}
    </div>
  </a>

  <!-- Wishlist (quiet, top-right) -->
  <button data-wish data-id={`${car.sourceSlug}-${car.id}`} aria-label={`Save ${car.name}`} aria-pressed="false"
    class="absolute right-3 top-3 grid h-9 w-9 place-items-center rounded-full text-ivory/70 backdrop-blur-sm transition-colors hover:text-gold"
    style="background:rgb(8 8 10 / 0.35)">
    <Heart class="h-[17px] w-[17px]" />
  </button>

  <div class="pt-5">
    <p class="text-[0.66rem] uppercase tracking-[0.2em] text-faint">{car.brand} · {cat?.label ?? car.category}</p>
    <a href={href}><h3 class="mt-1.5 truncate font-display text-[1.45rem] leading-tight text-ivory transition-colors group-hover:text-gold">{car.name}</h3></a>
    <div class="mt-3 flex items-end justify-between border-t border-ivory/8 pt-3">
      <p class="price-aed text-[0.95rem] text-gold">{fmtAED(car.priceDaily)} <span class="text-faint">/ day</span></p>
      {specLine && <p class="hidden text-[0.72rem] text-mist sm:block">{specLine}</p>}
    </div>
  </div>
</article>
