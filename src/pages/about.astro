---
import Layout from '../layouts/Layout.astro';
import ParallaxBand from '../components/ParallaxBand.astro';
import { about, whyChooseUs, brands, contact, site } from '../data/site';
import { getFleet } from '../lib/fleet';
import { Gem, BadgeCheck, Headset, MapPin, ShieldCheck } from '@lucide/astro';
const icons: Record<string, any> = { Gem, BadgeCheck, Headset, MapPin, ShieldCheck };
const fleet = await getFleet();
const visionImg = fleet.find((c) => c.brand === 'Rolls-Royce')?.images[0] ?? fleet[0].images[0];
---
<Layout title="About - Super Luxury Car Rental Dubai">
  <!-- Parallax header -->
  <ParallaxBand image="/film/poster.webp" alt="Dubai skyline at golden hour"
    height="h-[78vh] min-h-[500px]" eyebrow="About us" title="The luxury lifestyle Dubai has to offer." />

  <!-- Intro + stats -->
  <section class="lux-container py-20 lg:py-32">
    <div class="grid gap-14 lg:grid-cols-12 lg:gap-20">
      <p class="lg:col-span-7 font-display text-[clamp(1.6rem,3vw,2.5rem)] font-normal leading-[1.3] text-ivory" data-reveal>{about.intro}</p>
      <div class="lg:col-span-5 lg:pt-3">
        <div class="grid grid-cols-3 gap-6 border-t border-ivory/10 pt-8" data-reveal data-delay="80">
          <div><p class="font-display text-[2.6rem] leading-none text-gold-deep">{fleet.length}</p><p class="mt-2 text-[0.82rem] uppercase tracking-[0.14em] text-faint">cars</p></div>
          <div><p class="font-display text-[2.6rem] leading-none text-gold-deep">{brands.length}</p><p class="mt-2 text-[0.82rem] uppercase tracking-[0.14em] text-faint">marques</p></div>
          <div><p class="font-display text-[2.6rem] leading-none text-gold-deep">24/7</p><p class="mt-2 text-[0.82rem] uppercase tracking-[0.14em] text-faint">support</p></div>
        </div>
        <a href="/fleet" class="link-arrow mt-10" data-reveal data-delay="120">See the collection
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
      </div>
    </div>
  </section>

  <!-- Vision band -->
  <ParallaxBand image={visionImg} alt="Rolls-Royce" height="h-[72vh] min-h-[480px]" align="center"
    eyebrow="Our company vision" title={about.vision} />

  <!-- Values -->
  <section class="lux-container py-20 lg:py-32">
    <div class="mb-14 max-w-2xl">
      <p class="eyebrow mb-4" data-reveal>Our values</p>
      <h2 class="display-2 text-ivory" data-reveal>Customers, first.</h2>
    </div>
    <div class="grid gap-x-12 gap-y-10 sm:grid-cols-2">
      {about.values.map((v, i) => (
        <div class="flex items-start gap-5 border-t border-ivory/10 pt-7" data-reveal data-delay={(i % 2) * 60}>
          <span class="font-display text-[2rem] leading-none text-gold-deep/50">0{i + 1}</span>
          <p class="text-[1.05rem] leading-relaxed text-ivory/85">{v}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Why choose us -->
  <section class="bg-coal py-20 lg:py-32">
    <div class="lux-container">
      <div class="mb-16 max-w-2xl">
        <p class="eyebrow mb-4" data-reveal>Why Super Luxury</p>
        <h2 class="display-2 text-ivory" data-reveal>A standard you can feel.</h2>
      </div>
      <div class="grid gap-x-12 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
        {whyChooseUs.map((w, i) => {
          const Icon = icons[w.icon] ?? BadgeCheck;
          return (
            <div class="border-t border-ivory/12 pt-7" data-reveal data-delay={(i % 3) * 60}>
              <Icon class="h-7 w-7 text-gold-deep" stroke-width={1.3} />
              <h3 class="mt-5 font-display text-[1.7rem] leading-tight text-ivory">{w.title}</h3>
              <p class="mt-2.5 text-[0.95rem] leading-relaxed text-mist">{w.body}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <ParallaxBand image="/film/showcase-poster.webp" alt="Lamborghini Urus with Dubai skyline"
    height="h-[64vh] min-h-[440px]" align="center" eyebrow="Embrace the lifestyle"
    title="Your car is waiting." ctaHref="/fleet" ctaLabel="Browse the fleet" />
  <section class="lux-container flex flex-wrap items-center justify-center gap-4 py-16">
    <a href="/book" class="btn-gold">Book now</a>
    <a href="/contact" class="btn-primary">Contact us</a>
  </section>
</Layout>
