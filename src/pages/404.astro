---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Not found — Super Luxury Car Rental" navVariant="solid">
  <section class="relative grid min-h-[80svh] place-items-center overflow-hidden px-6 text-center">
    <div class="absolute inset-0 hero-glow opacity-70"></div>
    <div class="relative">
      <p class="font-display text-7xl font-bold text-gold sm:text-8xl">404</p>
      <h1 class="mt-4 font-display text-2xl font-semibold text-ivory sm:text-3xl">This road leads nowhere.</h1>
      <p class="mx-auto mt-3 max-w-md text-mist">The page you’re after has moved or never existed. Let’s get you back to the cars.</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/fleet" class="btn-gold px-7 py-3.5">Browse the fleet</a>
        <a href="/" class="btn-primary px-7 py-3.5">Home</a>
      </div>
    </div>
  </section>
</Layout>
