---
import Layout from '../../layouts/Layout.astro';
import ParallaxBand from '../../components/ParallaxBand.astro';
import FleetCard from '../../components/FleetCard.astro';
import { getFleet } from '../../lib/fleet';
import { Heart, MessageCircle } from '@lucide/astro';
import { contact } from '../../data/site';
const fleet = await getFleet();
const heroImg = fleet.find((c) => c.brand === 'Rolls-Royce')?.images[0] ?? '/film/showcase-poster.webp';
---
<Layout title="Saved cars - Super Luxury Car Rental">
  <!-- Parallax header -->
  <ParallaxBand image={heroImg} alt="A car from the Super Luxury collection"
    height="h-[64vh] min-h-[440px]" eyebrow="Your shortlist" title="Saved cars."
    text="The cars you've saved live here on this device. Send us your shortlist and we'll confirm availability and the best rate." />

  <section class="lux-container py-20 lg:py-28">
    <div data-wishgrid class="grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {fleet.map((car) => (
        <div data-wishitem data-id={`${car.sourceSlug}-${car.id}`} class="hidden"><FleetCard car={car} /></div>
      ))}
    </div>

    <!-- Empty state -->
    <div data-wishempty class="mx-auto max-w-xl py-16 text-center lg:py-24" data-reveal>
      <div class="mx-auto grid h-20 w-20 place-items-center rounded-full border border-gold/25 bg-gold/8 text-gold-deep">
        <Heart class="h-8 w-8" stroke-width={1.3} />
      </div>
      <h2 class="mt-8 font-display text-[clamp(1.8rem,3vw,2.6rem)] font-normal leading-tight text-ivory">No saved cars - yet.</h2>
      <p class="mx-auto mt-4 max-w-md text-[1rem] leading-relaxed text-mist">Tap the heart on any car as you browse the collection, and it will be waiting for you here when you're ready to decide.</p>
      <a href="/fleet" class="btn-gold mt-9 px-7 py-3.5">Browse the fleet
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
    </div>

    <!-- Shortlist CTA -->
    <div data-wishcta class="mt-16 hidden" data-reveal>
      <div class="overflow-hidden rounded-3xl border border-ivory/10 bg-coal">
        <div class="grid items-center gap-8 p-8 sm:p-12 lg:grid-cols-12 lg:gap-12 lg:p-16">
          <div class="lg:col-span-8">
            <p class="eyebrow mb-4">One message away</p>
            <h2 class="font-display text-[clamp(1.8rem,3vw,2.6rem)] font-normal leading-tight text-ivory">Ready when you are.</h2>
            <p class="mt-4 max-w-xl text-[1rem] leading-relaxed text-mist">Send your shortlist over WhatsApp and we'll come back with availability, weekly &amp; monthly rates, and delivery times across Dubai.</p>
          </div>
          <div class="flex flex-col gap-3 sm:flex-row lg:col-span-4 lg:flex-col lg:items-stretch">
            <a data-wa href={contact.whatsapp} target="_blank" rel="noopener" class="btn-gold justify-center px-7 py-3.5"><MessageCircle class="h-4 w-4" /> Send shortlist</a>
            <a href="/book" class="btn-primary justify-center px-7 py-3.5">Book now</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const items = Array.from(document.querySelectorAll('[data-wishitem]')) as HTMLElement[];
  const empty = document.querySelector('[data-wishempty]') as HTMLElement;
  const cta = document.querySelector('[data-wishcta]') as HTMLElement;
  const wa = document.querySelector('[data-wa]') as HTMLAnchorElement;
  const baseWa = wa?.href || '';

  function render() {
    let ids: string[] = [];
    try { ids = JSON.parse(localStorage.getItem('slcr-wishlist') || '[]'); } catch {}
    let count = 0;
    const names: string[] = [];
    items.forEach((it) => {
      const on = ids.includes(it.dataset.id || '');
      it.classList.toggle('hidden', !on);
      if (on) { count++; const n = it.querySelector('h3')?.textContent?.trim(); if (n) names.push(n); }
    });
    empty.classList.toggle('hidden', count > 0);
    cta.classList.toggle('hidden', count === 0);
    if (wa && count > 0) {
      const txt = encodeURIComponent(`Hi Super Luxury Car Rental, I'm interested in these cars: ${names.join(', ')}. Could you confirm availability and rates?`);
      wa.href = `${baseWa}&text=${txt}`;
    }
  }
  render();
  // live-update when hearts toggle elsewhere or storage changes
  document.addEventListener('wishlist:change', render);
  window.addEventListener('storage', render);
</script>
