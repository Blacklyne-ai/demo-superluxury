---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FleetCard from '../../components/FleetCard.astro';
import ParallaxBand from '../../components/ParallaxBand.astro';
import { getFleet, fmtAED, similar, shortName } from '../../lib/fleet';
import { categoryMap, contact } from '../../data/site';
import { Heart, Users, DoorOpen, Cog, Gauge, MapPin, CheckCircle2, ChevronRight, MessageCircle, Phone, CalendarCheck, ArrowLeft } from '@lucide/astro';

export async function getStaticPaths() {
  const entries = await getCollection('fleet');
  return entries.map((e) => ({ params: { slug: e.id }, props: { car: e.data } }));
}
const { car } = Astro.props;
const fleet = await getFleet();
const sims = similar(fleet, car, 3);
const cat = categoryMap[car.category];
const wishId = `${car.sourceSlug}-${car.id}`;
const waText = encodeURIComponent(`Hi Super Luxury Car Rental, I'd like to book the ${car.name} (${fmtAED(car.priceDaily)}/day). Is it available?`);
const specRows = [
  car.specs.engine && { icon: Gauge, label: 'Engine', value: car.specs.engine },
  car.specs.seats && { icon: Users, label: 'Seats', value: String(car.specs.seats) },
  car.specs.doors && { icon: DoorOpen, label: 'Doors', value: String(car.specs.doors) },
  car.specs.transmission && { icon: Cog, label: 'Transmission', value: car.specs.transmission },
  car.specs.mileagePerDayKm && { icon: MapPin, label: 'Mileage / day', value: `${car.specs.mileagePerDayKm} km` },
  car.specs.freePickup && { icon: CheckCircle2, label: 'Delivery', value: 'Free in Dubai' },
].filter(Boolean) as { icon: any; label: string; value: string }[];
---
<Layout title={`${car.name} - Rent in Dubai | Super Luxury Car Rental`} description={car.description?.slice(0, 155) || `Rent the ${car.name} in Dubai from ${fmtAED(car.priceDaily)}/day.`} image={car.images[0]} navVariant="solid">
  <div class="pt-[calc(var(--nav-h)+1.5rem)]">
    <!-- breadcrumb -->
    <div class="lux-container">
      <nav class="flex items-center gap-1.5 text-xs text-faint" aria-label="Breadcrumb">
        <a href="/fleet" class="hover:text-gold">Fleet</a><ChevronRight class="h-3 w-3" />
        <a href={`/fleet?category=${car.category}`} class="hover:text-gold">{cat?.label ?? car.category}</a><ChevronRight class="h-3 w-3" />
        <span class="text-mist">{car.name}</span>
      </nav>
    </div>

    <section class="lux-container grid gap-10 py-8 lg:grid-cols-[1.15fr_0.85fr] lg:gap-14 lg:py-10">
      <!-- Gallery -->
      <div>
        <div class="relative overflow-hidden rounded-2xl border border-ivory/10 bg-coal">
          <img data-main src={car.images[0]} alt={car.name} width="1280" height="853" class="aspect-[3/2] w-full object-cover" fetchpriority="high" decoding="async" />
          <button data-wish data-id={wishId} aria-label={`Save ${car.name}`} aria-pressed="false"
            class="absolute right-4 top-4 grid h-11 w-11 place-items-center rounded-full border border-ivory/15 bg-ink/55 text-ivory/85 backdrop-blur-sm transition-colors hover:text-gold">
            <Heart class="h-5 w-5" />
          </button>
        </div>
        {car.images.length > 1 && (
          <div class="mt-3 grid grid-cols-5 gap-3">
            {car.images.slice(0, 10).map((img, i) => (
              <button data-thumb={img} class:list={['overflow-hidden rounded-lg border transition-colors', i === 0 ? 'border-gold/60' : 'border-ivory/10 hover:border-ivory/30']}>
                <img src={img} alt={`${car.name} ${i + 1}`} width="200" height="150" loading="lazy" decoding="async" class="aspect-[4/3] w-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div class="lg:pt-2">
        <div class="flex items-center gap-2">
          <span class="chip-gold">{cat?.label ?? car.category}</span>
          <span class="chip">{car.brand}</span>
        </div>
        <h1 class="mt-4 font-display text-[2.4rem] leading-[1.05] text-ivory sm:text-[3rem]">{car.name}</h1>

        <!-- price card -->
        <div class="mt-6 rounded-2xl border border-ivory/10 bg-graphite p-6">
          <div class="flex items-end justify-between">
            <div>
              <p class="text-xs uppercase tracking-wide2 text-faint">Daily rate</p>
              <p class="price-aed font-display text-4xl font-semibold text-gold">{fmtAED(car.priceDaily)}</p>
            </div>
            <p class="text-right text-xs text-faint">incl. 250 km/day<br />free Dubai delivery</p>
          </div>
          <div class="mt-5 grid grid-cols-2 gap-3 border-t border-ivory/8 pt-5 text-sm">
            <div><p class="text-faint">Weekly</p><p class="text-ivory/80">On request</p></div>
            <div><p class="text-faint">Monthly</p><p class="text-ivory/80">On request</p></div>
          </div>
          <div class="mt-5 flex flex-col gap-2.5">
            <a href={`/book?car=${encodeURIComponent(car.name)}`} class="btn-gold py-3.5"><CalendarCheck class="h-4 w-4" /> Book this car</a>
            <div class="grid grid-cols-2 gap-2.5">
              <a href={`${contact.whatsapp}&text=${waText}`} target="_blank" rel="noopener" class="btn-primary py-3"><MessageCircle class="h-4 w-4" /> WhatsApp</a>
              <a href={contact.phonePrimaryHref} class="btn-primary py-3"><Phone class="h-4 w-4" /> Call</a>
            </div>
          </div>
        </div>

        <!-- specs -->
        {specRows.length > 0 && (
          <div class="mt-6 grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-ivory/10 bg-ivory/10 sm:grid-cols-3">
            {specRows.map((s) => (
              <div class="bg-graphite p-4">
                <s.icon class="h-5 w-5 text-gold/80" />
                <p class="mt-2 text-[0.72rem] uppercase tracking-wide text-faint">{s.label}</p>
                <p class="text-sm font-medium text-ivory">{s.value}</p>
              </div>
            ))}
          </div>
        )}

        {car.description && (
          <div class="mt-6">
            <h2 class="font-display text-lg font-semibold text-ivory">About this car</h2>
            <p class="mt-3 text-sm leading-relaxed text-mist">{car.description}</p>
          </div>
        )}
        <p class="mt-5 text-xs text-faint">Drivers must be 21+ with a valid licence. Full <a href="/terms" class="text-gold/80 underline underline-offset-2 hover:text-gold">rental terms</a> apply. Weekly &amp; monthly rates and security deposit are confirmed on request.</p>
      </div>
    </section>

    <!-- Similar -->
    {sims.length > 0 && (
      <section class="border-t border-ivory/8 bg-coal py-16 lg:py-20">
        <div class="lux-container">
          <div class="flex items-end justify-between">
            <h2 class="font-display text-2xl font-semibold tracking-tight2 text-ivory sm:text-3xl">You may also like</h2>
            <a href="/fleet" class="inline-flex items-center gap-1.5 text-sm font-medium text-gold hover:text-gold-lite"><ArrowLeft class="h-4 w-4" /> All cars</a>
          </div>
          <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {sims.map((c) => <FleetCard car={c} />)}
          </div>
        </div>
      </section>
    )}
  </div>

  <!-- Closing CTA band -->
  <ParallaxBand image={car.images[car.images.length > 2 ? 2 : 0]} alt={car.name}
    height="h-[64vh] min-h-[440px]" align="center" eyebrow={`${fmtAED(car.priceDaily)} / day · free Dubai delivery`}
    title={`Drive the ${shortName(car.id, car.name)}.`} ctaHref={`/book?car=${encodeURIComponent(car.name)}`} ctaLabel="Book this car" />
</Layout>

<script>
  const main = document.querySelector('[data-main]') as HTMLImageElement | null;
  const thumbs = Array.from(document.querySelectorAll('[data-thumb]')) as HTMLElement[];
  thumbs.forEach((t) => t.addEventListener('click', () => {
    if (!main) return;
    main.src = t.dataset.thumb || main.src;
    thumbs.forEach((x) => { x.classList.remove('border-gold/60'); x.classList.add('border-ivory/10'); });
    t.classList.add('border-gold/60'); t.classList.remove('border-ivory/10');
  }));
</script>
