---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FleetCard from '../components/FleetCard.astro';
import { getFleet, catCounts } from '../lib/fleet';
import { categories, contact } from '../data/site';
import { MapPin, Phone, MessageCircle, Truck, Headset, BadgeCheck, UserRound } from '@lucide/astro';

const fleet = await getFleet();
const counts = catCounts(fleet);
const showcase = fleet.find((c) => c.id === '129')?.images[1] ?? fleet[0].images[0]; // green Urus
const perks = [
  { icon: Truck, t: 'Free delivery', d: 'Anywhere in Dubai' },
  { icon: Headset, t: '24/7 support', d: 'Always reachable' },
  { icon: BadgeCheck, t: 'Transparent pricing', d: 'No hidden charges' },
  { icon: UserRound, t: 'Chauffeur', d: 'On request' },
];
---
<Layout navVariant="solid">
  <Hero />

  <!-- FLEET — cars first -->
  <section id="fleet" class="scroll-mt-[var(--nav-h)] pt-16 lg:pt-24">
    <div class="lux-wide mb-8 flex items-end justify-between">
      <div>
        <p class="eyebrow mb-3" data-reveal>The fleet</p>
        <h2 class="display-2" data-reveal>Pick your car.</h2>
      </div>
      <a href="/fleet" class="link-arrow hidden sm:inline-flex" data-reveal>All {fleet.length} cars
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
    </div>

    <!-- minimal category options -->
    <div class="sticky top-[var(--nav-h)] z-30 -mx-px border-y border-ivory/10 bg-ink/85 backdrop-blur-xl">
      <div class="lux-wide flex items-center gap-2 overflow-x-auto py-4 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        <button data-cat-pill data-cat="" class="cat-pill is-on">All</button>
        {categories.map((c) => (
          <button data-cat-pill data-cat={c.slug} class="cat-pill">{c.label}</button>
        ))}
        <span class="ml-auto shrink-0 pl-4 text-[0.72rem] tracking-[0.12em] text-faint"><span data-count>{fleet.length}</span> cars</span>
      </div>
    </div>

    <div class="lux-wide py-12">
      <div data-grid class="grid grid-cols-2 gap-x-5 gap-y-10 md:grid-cols-3 lg:grid-cols-4">
        {fleet.map((car, i) => <FleetCard car={car} eager={i < 8} />)}
      </div>
      <div class="mt-14 flex flex-col items-center gap-5">
        <button data-showmore class="btn-primary">Show more cars</button>
        <a href="/fleet" class="text-[0.78rem] uppercase tracking-[0.14em] text-faint transition-colors hover:text-gold-deep">Browse all {fleet.length} with filters →</a>
      </div>
    </div>
  </section>

  <!-- Parallax showcase -->
  <section class="relative my-8 h-[70vh] overflow-hidden">
    <img src="/film/showcase-poster.webp" alt="Lamborghini Urus with the Dubai skyline" class="absolute inset-0 h-full w-full object-cover" loading="lazy" decoding="async" />
    <video data-showcase-video class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700" poster="/film/showcase-poster.webp" muted loop playsinline preload="none" aria-hidden="true">
      <source src="/film/showcase-dubai.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/15 to-black/30"></div>
    <div class="lux-wide absolute inset-0 z-10 flex flex-col items-start justify-center text-white">
      <p class="mb-4 text-[0.7rem] font-semibold uppercase tracking-[0.3em] text-white/75" data-reveal>Delivered to you</p>
      <h2 class="max-w-2xl font-display text-[clamp(2rem,4.5vw,3.6rem)] font-normal leading-[1.05]" data-reveal data-delay="60">Your car, wherever you are in Dubai.</h2>
      <a href="/book" class="mt-8 inline-flex items-center gap-2 rounded-full bg-white px-7 py-3.5 text-[0.82rem] font-semibold uppercase tracking-[0.14em] text-ink transition hover:bg-gold hover:text-white" data-reveal data-delay="120">Book now</a>
    </div>
  </section>

  <!-- Perks (short) -->
  <section class="lux-wide py-16 lg:py-24">
    <div class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-ivory/10 bg-ivory/10 lg:grid-cols-4">
      {perks.map((p, i) => (
        <div class="bg-graphite p-7 text-center" data-reveal data-delay={(i % 4) * 60}>
          <p.icon class="mx-auto h-6 w-6 text-gold" stroke-width={1.4} />
          <p class="mt-4 font-display text-[1.5rem] leading-tight text-ivory">{p.t}</p>
          <p class="mt-1 text-[0.82rem] text-mist">{p.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Contact (short) -->
  <section class="lux-wide grid gap-12 pb-24 lg:grid-cols-2 lg:items-center lg:gap-16">
    <div>
      <p class="eyebrow mb-4" data-reveal>Al Barsha · Dubai</p>
      <h2 class="display-2" data-reveal>Ready to drive?</h2>
      <div class="mt-7 space-y-3 text-[0.95rem]" data-reveal data-delay="60">
        <p class="flex items-center gap-3 text-ivory/85"><MapPin class="h-4 w-4 text-gold" stroke-width={1.5} />{contact.address}</p>
        <p class="flex items-center gap-3 text-ivory/85"><Phone class="h-4 w-4 text-gold" stroke-width={1.5} /><a href={contact.phonePrimaryHref} class="hover:text-gold-deep">{contact.phonePrimary}</a></p>
      </div>
      <div class="mt-8 flex flex-wrap items-center gap-3" data-reveal data-delay="100">
        <a href={contact.whatsapp} target="_blank" rel="noopener" class="btn-gold"><MessageCircle class="h-4 w-4" /> WhatsApp</a>
        <a href="/contact" class="btn-primary">Contact &amp; map</a>
      </div>
    </div>
    <div class="overflow-hidden rounded-2xl border border-ivory/10" data-reveal data-delay="80">
      <iframe title="Map — Al Barsha, Dubai" src={`https://maps.google.com/maps?q=${encodeURIComponent(contact.mapQuery)}&t=m&z=13&output=embed`} class="h-[340px] w-full lg:h-[400px]" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </section>
</Layout>

<script>
  // category-only filter for the homepage grid
  const grid = document.querySelector('[data-grid]') as HTMLElement | null;
  if (grid) {
    const PAGE = 12;
    const cards = Array.from(grid.querySelectorAll('[data-card]')) as HTMLElement[];
    const pills = Array.from(document.querySelectorAll('[data-cat-pill]')) as HTMLElement[];
    const countEl = document.querySelector('[data-count]') as HTMLElement;
    const moreBtn = document.querySelector('[data-showmore]') as HTMLElement | null;
    let cat = '';
    let limit = PAGE;
    function apply() {
      let total = 0, shown = 0;
      cards.forEach((c) => {
        const match = !cat || (c.dataset.cats || '').split(',').includes(cat);
        if (match) { total++; const vis = shown < limit; c.style.display = vis ? '' : 'none'; if (vis) shown++; }
        else c.style.display = 'none';
      });
      if (countEl) countEl.textContent = String(total);
      if (moreBtn) moreBtn.style.display = shown < total ? '' : 'none';
    }
    pills.forEach((p) => p.addEventListener('click', () => {
      pills.forEach((x) => x.classList.toggle('is-on', x === p));
      cat = p.dataset.cat || ''; limit = PAGE; apply();
    }));
    moreBtn?.addEventListener('click', () => { limit += PAGE; apply(); });
    apply();
  }

  // showcase video — lazy play when scrolled into view (skip for reduced-motion)
  const sv = document.querySelector('[data-showcase-video]') as HTMLVideoElement | null;
  if (sv && !window.matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        sv.preload = 'auto';
        sv.addEventListener('canplay', () => { sv.style.opacity = '1'; sv.play().catch(() => {}); }, { once: true });
        sv.load();
        io.disconnect();
      });
    }, { rootMargin: '200px' });
    io.observe(sv);
  }
</script>

