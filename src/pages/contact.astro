---
import Layout from '../layouts/Layout.astro';
import ParallaxBand from '../components/ParallaxBand.astro';
import { contact, site } from '../data/site';
import { getFleet } from '../lib/fleet';
import { MessageCircle, Phone, Mail, MapPin, Clock, ArrowUpRight } from '@lucide/astro';
const fleet = await getFleet();
const header = fleet.find((c) => c.brand === 'Bentley')?.images[0] ?? fleet[0].images[0];
const tiles = [
  { icon: MessageCircle, label: 'WhatsApp', value: contact.whatsappNumber, href: contact.whatsapp, note: 'Fastest reply - chat now', ext: true },
  { icon: Phone, label: 'Call us', value: contact.phonePrimary, href: contact.phonePrimaryHref, note: contact.phoneSecondary },
  { icon: Mail, label: 'Email', value: contact.email, href: contact.emailHref, note: 'For longer enquiries' },
];
---
<Layout title="Contact - Super Luxury Car Rental, Al Barsha Dubai">
  <!-- Parallax header -->
  <ParallaxBand image={header} alt="Bentley in Dubai" height="h-[68vh] min-h-[460px]"
    eyebrow="Get in touch" title="Let’s get you driving."
    text="Tell us the car, the dates and where you are in Dubai - we deliver across the city." />

  <!-- Tiles -->
  <section class="lux-container py-20 lg:py-28">
    <div class="grid gap-5 sm:grid-cols-3">
      {tiles.map((t, i) => (
        <a href={t.href} target={t.ext ? '_blank' : undefined} rel={t.ext ? 'noopener' : undefined}
          class="group rounded-2xl border border-ivory/10 bg-graphite p-8 transition-all duration-500 hover:-translate-y-1 hover:border-gold/40 hover:shadow-[0_24px_60px_-28px_rgba(0,0,0,0.25)]" data-reveal data-delay={i * 70}>
          <div class="flex items-center justify-between">
            <div class="grid h-13 w-13 place-items-center rounded-xl border border-gold/25 bg-gold/10 p-3 text-gold-deep"><t.icon class="h-6 w-6" stroke-width={1.4} /></div>
            <ArrowUpRight class="h-5 w-5 text-faint transition-colors group-hover:text-gold-deep" />
          </div>
          <p class="mt-6 text-xs uppercase tracking-[0.18em] text-faint">{t.label}</p>
          <p class="mt-1 font-display text-[1.5rem] text-ivory">{t.value}</p>
          <p class="mt-1 text-sm text-mist">{t.note}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Address + map -->
  <section class="bg-coal py-20 lg:py-28">
    <div class="lux-container grid gap-12 lg:grid-cols-2 lg:items-center lg:gap-16">
      <div data-reveal>
        <p class="eyebrow mb-4">Al Barsha · Dubai</p>
        <h2 class="display-2 text-ivory">Visit the showroom.</h2>
        <ul class="mt-9 space-y-6 text-ivory/85">
          <li class="flex items-start gap-4"><MapPin class="mt-0.5 h-5 w-5 shrink-0 text-gold-deep" stroke-width={1.5} /><span>{contact.address}<br /><span class="text-mist">{site.country}</span></span></li>
          <li class="flex items-start gap-4"><Clock class="mt-0.5 h-5 w-5 shrink-0 text-gold-deep" stroke-width={1.5} /><span>Open 24/7 - call or message any time<br /><span class="text-mist">support around the clock</span></span></li>
          <li class="flex items-start gap-4"><Phone class="mt-0.5 h-5 w-5 shrink-0 text-gold-deep" stroke-width={1.5} /><span><a href={contact.phonePrimaryHref} class="hover:text-gold-deep">{contact.phonePrimary}</a> · <a href={contact.phoneSecondaryHref} class="hover:text-gold-deep">{contact.phoneSecondary}</a></span></li>
        </ul>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href={contact.whatsapp} target="_blank" rel="noopener" class="btn-gold"><MessageCircle class="h-4 w-4" /> WhatsApp</a>
          <a href="/book" class="btn-primary">Book a car</a>
        </div>
        <div class="mt-8 flex items-center gap-4 text-sm">
          <a href={contact.instagram} target="_blank" rel="noopener" class="text-mist hover:text-gold-deep">Instagram</a>
          <span class="text-faint">·</span>
          <a href={contact.facebook} target="_blank" rel="noopener" class="text-mist hover:text-gold-deep">Facebook</a>
        </div>
      </div>
      <div class="overflow-hidden rounded-2xl border border-ivory/10 shadow-[0_24px_60px_-30px_rgba(0,0,0,0.3)]" data-reveal data-delay="80">
        <iframe title="Map - Al Barsha, Dubai" src={`https://maps.google.com/maps?q=${encodeURIComponent(contact.mapQuery)}&t=m&z=13&output=embed`} class="h-[380px] w-full lg:h-[460px]" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </section>
</Layout>
