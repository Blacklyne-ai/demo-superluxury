---
import Layout from '../../layouts/Layout.astro';
import ParallaxBand from '../../components/ParallaxBand.astro';
import { posts, contact } from '../../data/site';
import { getFleet } from '../../lib/fleet';
import { ArrowLeft, MessageCircle } from '@lucide/astro';

export async function getStaticPaths() {
  const fleet = await getFleet();
  const pick = (brand: string) => fleet.find((c) => c.brand === brand)?.images[0] ?? fleet[0].images[0];
  const coverFor: Record<string, string> = {
    'best-chauffeur-services-in-dubai': pick('Rolls-Royce'),
    'drive-dubai-in-style': pick('Lamborghini'),
    'valentines-day-luxury-car-rental-ideas': pick('Ferrari'),
    'ultimate-guide-to-lamborghini-rental-in-dubai': pick('Lamborghini'),
    'top-luxury-car-rental-companies-in-dubai': pick('Bentley'),
    'how-to-book-online-in-dubai': pick('Porsche'),
  };
  return posts.map((p) => ({ params: { slug: p.slug }, props: { post: p, cover: coverFor[p.slug] } }));
}
const { post, cover } = Astro.props;
const fmtDate = (d: string) => new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
const more = posts.filter((p) => p.slug !== post.slug).slice(0, 3);
---
<Layout title={`${post.title} - Super Luxury Car Rental`} description={post.excerpt ?? post.title} image={cover}>
  <article>
    <!-- Cinematic cover header -->
    <section class="relative h-[82vh] min-h-[520px] overflow-hidden">
      <div data-parallax="0.18" class="absolute inset-0">
        <img src={cover} alt={post.title} class="parallax h-full w-full object-cover" decoding="async" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/35 to-black/45"></div>
      <div class="lux-wide absolute inset-0 z-10 flex flex-col justify-end pb-16 text-white lg:pb-20">
        <a href="/blog" class="mb-7 inline-flex items-center gap-1.5 text-[0.8rem] font-medium uppercase tracking-[0.18em] text-white/75 transition hover:text-white" data-reveal><ArrowLeft class="h-4 w-4" /> Journal</a>
        <p class="mb-5 text-[0.72rem] font-semibold uppercase tracking-[0.3em] text-white/75" data-reveal data-delay="60">{fmtDate(post.date)}</p>
        <h1 class="max-w-4xl font-display text-[clamp(2rem,4.5vw,3.8rem)] font-normal leading-[1.05]" data-reveal data-delay="120">{post.title}</h1>
      </div>
    </section>

    <!-- Article body -->
    <div class="lux-narrow py-20 lg:py-28">
      {post.excerpt && (
        <p class="font-display text-[clamp(1.4rem,2.6vw,2rem)] font-normal leading-[1.35] text-ivory" data-reveal>{post.excerpt}</p>
      )}

      <div class="mt-12 space-y-6 text-[1.08rem] leading-[1.85] text-ivory/80" data-reveal data-delay="60">
        <p>
          Dubai rewards the people who arrive prepared. The right car is rarely about horsepower alone - it is about how the
          city receives you when the door opens. That is the thread running through everything we do, and the reason this
          journal exists: to share what we have learned moving people through this city, one journey at a time.
        </p>
        <p>
          Our team is on hand to translate any of this into a real itinerary - the marque, the rate, the delivery window and
          the small details that make a difference. Read on, or simply tell us where you're headed and we'll take it from there.
        </p>
      </div>

      <!-- Inline CTA -->
      <div class="mt-14 rounded-2xl border border-ivory/10 bg-coal p-8 lg:p-10" data-reveal data-delay="120">
        <p class="font-display text-[1.5rem] leading-snug text-ivory">Want the full story, or planning a trip?</p>
        <p class="mt-3 max-w-lg text-[0.98rem] leading-relaxed text-mist">Our team is one message away - we'll match you with the right car and the right rate, and have it where you need it.</p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href={contact.whatsapp} target="_blank" rel="noopener" class="btn-gold px-6 py-3"><MessageCircle class="h-4 w-4" /> WhatsApp us</a>
          <a href="/fleet" class="btn-primary px-6 py-3">Browse the fleet</a>
        </div>
      </div>
    </div>

    <!-- More from the journal -->
    <section class="bg-coal py-20 lg:py-28">
      <div class="lux-container">
        <div class="mb-12 flex items-end justify-between gap-6">
          <div>
            <p class="eyebrow mb-3" data-reveal>Keep reading</p>
            <h2 class="display-2 text-ivory" data-reveal data-delay="60">More from the journal.</h2>
          </div>
          <a href="/blog" class="link-arrow hidden shrink-0 sm:inline-flex" data-reveal data-delay="120">All stories
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>
        <div class="grid gap-x-8 gap-y-12 sm:grid-cols-3">
          {more.map((p, i) => (
            <a href={`/blog/${p.slug}`} class="group flex flex-col border-t border-ivory/12 pt-7" data-reveal data-delay={(i % 3) * 60}>
              <p class="text-[0.72rem] uppercase tracking-[0.18em] text-faint">{fmtDate(p.date)}</p>
              <h3 class="mt-3 font-display text-[1.5rem] font-normal leading-[1.18] text-ivory transition-colors group-hover:text-gold-deep">{p.title}</h3>
              <span class="link-arrow mt-6">Read
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </article>
</Layout>
