---
import Layout from '../../layouts/Layout.astro';
import { posts } from '../../data/site';
import { getFleet } from '../../lib/fleet';
import { ArrowUpRight } from '@lucide/astro';
const fleet = await getFleet();
const fmtDate = (d: string) => new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
const covers = [
  fleet.find((c) => c.brand === 'Lamborghini')?.images[0],
  fleet.find((c) => c.brand === 'Rolls-Royce')?.images[0],
  fleet.find((c) => c.brand === 'Ferrari')?.images[0],
  fleet.find((c) => c.brand === 'Bentley')?.images[0],
  fleet.find((c) => c.brand === 'Range Rover')?.images[0],
  fleet.find((c) => c.brand === 'Porsche')?.images[0],
];
---
<Layout title="Journal — Super Luxury Car Rental Dubai" navVariant="solid">
  <section class="border-b border-ivory/8 bg-coal pt-[calc(var(--nav-h)+4rem)]">
    <div class="lux-container pb-12">
      <p class="eyebrow mb-4">Journal</p>
      <h1 class="font-display text-4xl font-semibold tracking-tight2 text-ivory sm:text-5xl lg:text-6xl">Dubai, on wheels.</h1>
      <p class="mt-4 max-w-xl text-mist">Car-rental trends, new launches and the city — notes from the Super Luxury team.</p>
    </div>
  </section>

  <section class="lux-container py-14 lg:py-20">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((p, i) => (
        <a href={`/blog/${p.slug}`} class="group flex flex-col overflow-hidden rounded-2xl border border-ivory/10 bg-graphite transition-colors duration-500 hover:border-gold/35" data-reveal data-delay={(i % 3) * 60}>
          <div class="relative aspect-[16/10] overflow-hidden bg-coal">
            {covers[i] && <img src={covers[i]} alt="" width="640" height="400" loading="lazy" decoding="async" class="h-full w-full object-cover opacity-70 transition-all duration-700 group-hover:scale-105 group-hover:opacity-90" />}
            <div class="absolute inset-0 bg-gradient-to-t from-graphite to-transparent"></div>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <p class="text-xs uppercase tracking-wide2 text-faint">{fmtDate(p.date)}</p>
            <h2 class="mt-2 font-display text-lg font-semibold leading-snug text-ivory transition-colors group-hover:text-gold">{p.title}</h2>
            {p.excerpt && <p class="mt-3 line-clamp-3 text-sm leading-relaxed text-mist">{p.excerpt}</p>}
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-gold/90">Read <ArrowUpRight class="h-4 w-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" /></span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
