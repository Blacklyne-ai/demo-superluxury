---
import Layout from '../../layouts/Layout.astro';
import ParallaxBand from '../../components/ParallaxBand.astro';
import { posts } from '../../data/site';
import { getFleet } from '../../lib/fleet';
const fleet = await getFleet();
const fmtDate = (d: string) => new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
const covers = [
  fleet.find((c) => c.brand === 'Lamborghini')?.images[0],
  fleet.find((c) => c.brand === 'Rolls-Royce')?.images[0],
  fleet.find((c) => c.brand === 'Ferrari')?.images[0],
  fleet.find((c) => c.brand === 'Bentley')?.images[0],
  fleet.find((c) => c.brand === 'Range Rover')?.images[0],
  fleet.find((c) => c.brand === 'Porsche')?.images[0],
];
const heroImg = fleet.find((c) => c.brand === 'Lamborghini')?.images[0] ?? '/film/showcase-poster.webp';
const featured = posts[0];
const rest = posts.slice(1);
---
<Layout title="Journal — Super Luxury Car Rental Dubai">
  <!-- Parallax header -->
  <ParallaxBand image="/film/showcase-poster.webp" alt="Lamborghini Urus with the Dubai skyline"
    height="h-[78vh] min-h-[500px]" eyebrow="Journal" title="Dubai, on wheels."
    text="Car-rental trends, new launches and the city — notes from the Super Luxury team." />

  <!-- Section heading -->
  <section class="lux-container pt-20 lg:pt-28">
    <div class="grid items-end gap-8 border-b border-ivory/10 pb-10 lg:grid-cols-12">
      <div class="lg:col-span-8">
        <p class="eyebrow mb-4" data-reveal>The reading room</p>
        <h1 class="display-2 text-ivory" data-reveal data-delay="60">Stories from the front seat.</h1>
      </div>
      <p class="text-[0.98rem] leading-relaxed text-mist lg:col-span-4 lg:pb-2" data-reveal data-delay="120">
        A slow, considered look at the cars, the city and the way Dubai moves — written by the people who hand you the keys.
      </p>
    </div>
  </section>

  <!-- Featured post -->
  <section class="lux-container pt-12 lg:pt-16">
    <a href={`/blog/${featured.slug}`} class="group grid items-stretch overflow-hidden rounded-3xl border border-ivory/10 bg-graphite transition-colors duration-500 hover:border-gold/35 lg:grid-cols-2" data-reveal>
      <div class="relative aspect-[16/11] overflow-hidden bg-coal lg:aspect-auto lg:min-h-[460px]">
        {covers[0] && <img src={covers[0]} alt="" width="960" height="640" loading="lazy" decoding="async" class="h-full w-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]" />}
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        <span class="absolute left-5 top-5 rounded-full bg-white/90 px-4 py-1.5 text-[0.66rem] font-semibold uppercase tracking-[0.2em] text-ink">Featured</span>
      </div>
      <div class="flex flex-col justify-center px-7 py-12 lg:px-14 lg:py-16">
        <p class="text-[0.75rem] uppercase tracking-[0.18em] text-faint">{fmtDate(featured.date)}</p>
        <h2 class="mt-5 font-display text-[clamp(1.9rem,3.2vw,2.8rem)] font-normal leading-[1.1] text-ivory transition-colors group-hover:text-gold-deep">{featured.title}</h2>
        {featured.excerpt && <p class="mt-5 max-w-xl text-[1rem] leading-relaxed text-mist line-clamp-4">{featured.excerpt}</p>}
        <span class="link-arrow mt-9">Read the story
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
      </div>
    </a>
  </section>

  <!-- Editorial grid -->
  <section class="lux-container py-16 lg:py-24">
    <div class="grid gap-x-8 gap-y-14 sm:grid-cols-2 lg:grid-cols-3">
      {rest.map((p, i) => (
        <a href={`/blog/${p.slug}`} class="group flex flex-col" data-reveal data-delay={(i % 3) * 60}>
          <div class="relative aspect-[16/11] overflow-hidden rounded-2xl border border-ivory/10 bg-coal">
            {covers[i + 1] && <img src={covers[i + 1]} alt="" width="640" height="440" loading="lazy" decoding="async" class="h-full w-full object-cover transition-transform duration-[1100ms] ease-out group-hover:scale-[1.05]" />}
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          </div>
          <p class="mt-6 text-[0.72rem] uppercase tracking-[0.18em] text-faint">{fmtDate(p.date)}</p>
          <h2 class="mt-3 font-display text-[1.55rem] font-normal leading-[1.15] text-ivory transition-colors group-hover:text-gold-deep">{p.title}</h2>
          {p.excerpt && <p class="mt-3 line-clamp-3 text-[0.95rem] leading-relaxed text-mist">{p.excerpt}</p>}
          <span class="link-arrow mt-6">Read
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </a>
      ))}
    </div>
  </section>

  <!-- Closing band -->
  <ParallaxBand image={heroImg} alt="Lamborghini in Dubai" height="h-[58vh] min-h-[400px]" align="center"
    eyebrow="When words aren't enough" title="See it in the metal."
    ctaHref="/fleet" ctaLabel="Browse the fleet" />
</Layout>
